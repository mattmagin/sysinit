{{- /* Hyprlock configuration — managed by chezmoi */ -}}
{{- /* Note: hyprlock uses rgba(r,g,b, alpha) or rgb(hex) format */ -}}
{{- $bgHex := trimPrefix "#" .theme.background -}}
{{- $fgHex := trimPrefix "#" .theme.foreground -}}
{{- $acHex := trimPrefix "#" .theme.accent -}}

$color = rgb({{ $bgHex }})
$inner_color = rgba({{ $bgHex }}cc)
$outer_color = rgb({{ $fgHex }})
$font_color = rgb({{ $fgHex }})
$check_color = rgb({{ $acHex }})

general {
  ignore_empty_input = true
}

background {
  monitor =
  color = $color
  path = ~/.config/omarchy/current/background
  blur_passes = 3
}

animations {
  enabled = false
}

input-field {
  monitor =
  size = 650, 100
  position = 0, 0
  halign = center
  valign = center

  inner_color = $inner_color
  outer_color = $outer_color
  outline_thickness = 4

  font_family = JetBrainsMono Nerd Font
  font_color = $font_color

  placeholder_text = Enter Password
  check_color = $check_color
  fail_text = <i>$FAIL ($ATTEMPTS)</i>

  rounding = 0
  shadow_passes = 0
  fade_on_empty = false
}

auth {
  fingerprint:enabled = false
}
